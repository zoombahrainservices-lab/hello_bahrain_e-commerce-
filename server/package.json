{
  "name": "hellobahrain-server",
  "version": "1.0.0",
  "description": "Express API server for HelloBahrain e-commerce",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node --project tsconfig.dev.json src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node src/seed.ts",
    "verify-db": "ts-node src/verify-db.ts",
    "setup-db": "ts-node src/setup-db-direct.ts",
    "add-products": "ts-node src/add-products.ts",
    "add-phone-column": "ts-node src/add-phone-column.ts",
    "apply-schema-updates": "ts-node src/apply-schema-updates.ts",
    "apply-banner-schema-updates": "ts-node src/apply-banner-schema-updates.ts",
    "check-banner-columns": "ts-node src/check-banner-columns.ts",
    "fix-banner-alignment": "ts-node --project tsconfig.dev.json src/fix-banner-alignment.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/pg": "^8.15.6",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
